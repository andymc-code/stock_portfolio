# ============================================
# Stock Portfolio App — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to git!
# ============================================

# --- Gemini API (Optional: used only for AI Insights) ---
# Get your key from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# --- Finnhub API (Required: used for live stock price fetching) ---
# Get your free key from: https://finnhub.io/
VITE_FINNHUB_API_KEY=

# --- Alpha Vantage API (Optional: used for Top Gainers / Losers / Active screeners) ---
# Get your free key from: https://www.alphavantage.co/support/#api-key
VITE_ALPHAVANTAGE_API_KEY=

# --- Firebase ---
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
